{
  "name": "opencats-modern-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean:build": "node ./scripts/clean-build-output.mjs",
    "dev": "vite",
    "build": "npm run clean:build && vite build --mode production",
    "build:dev": "npm run clean:build && vite build --mode development",
    "preview": "vite preview",
    "verify:build": "node ./scripts/verify-build-output.mjs",
    "compare:legacy-routes": "node ./scripts/compare-legacy-modern-routes.mjs",
    "verify:bridge-wildcards": "node ./scripts/verify-bridge-wildcard-retirement.mjs",
    "verify:no-bridge-actions": "node ./scripts/verify-no-bridge-actions.mjs",
    "verify:zero-legacy-dependent": "node ./scripts/verify-modernization-zero-legacy-dependent.mjs",
    "verify:in-scope-routes": "node ./scripts/verify-no-inscope-wildcard-fallbacks.mjs",
    "verify:legacy-fallback-links": "node ./scripts/verify-legacy-fallback-links.mjs",
    "verify:shell-noscript-fallback": "node ./scripts/verify-shell-noscript-fallback.mjs",
    "coverage:matrix": "node ./scripts/generate-coverage-matrix.mjs",
    "parity:routes": "node ./scripts/generate-route-parity-checklist.mjs",
    "modernization:board": "node ./scripts/generate-modernization-board.mjs",
    "smoke:routes": "node ./scripts/smoke-modern-routes.mjs",
    "smoke:endpoints": "node ./scripts/smoke-modern-endpoints.mjs",
    "smoke:playwright": "playwright test --config=playwright.config.mjs",
    "sanity:modern": "node ./scripts/modern-sanity-report.mjs",
    "scorecard:prefill": "node ./scripts/prefill-rollout-scorecard.mjs",
    "fixtures:lint": "node ./scripts/lint-smoke-fixtures.mjs",
    "fixtures:coverage": "node ./scripts/generate-smoke-fixture-coverage.mjs",
    "deprecation:validate": "node ./scripts/validate-deprecation-signoff.mjs",
    "cutover:evidence": "node ./scripts/generate-cutover-evidence-links.mjs",
    "ownership:reminder": "node ./scripts/generate-ownership-review-reminder.mjs",
    "quality:gate": "node ./scripts/quality-gate.mjs"
  },
  "dependencies": {
    "@toast-ui/editor": "^3.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
